{{- if eq .chezmoi.os "darwin" -}}
#!/usr/bin/env bash

if ! command -v brew &> /dev/null
then
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

{{ range .brewfiles -}}
# {{ . }} hash: {{ include (print "lib/" .) | sha256sum }}
brew bundle --quiet --force --file={{ joinPath $.chezmoi.sourceDir "lib" . | quote }}
{{ end -}}

{{ end -}}
