{{- if eq .chezmoi.os "darwin" -}}
#!/usr/bin/env bash

{{ if .resetDock }}
# Empty dock
defaults delete com.apple.dock persistent-apps 2>/dev/null || true
defaults write com.apple.dock persistent-apps -array '()'
{{ end }}

# Enable auto-hide
defaults write com.apple.dock autohide -bool true

# Disable recent apps in Dock
defaults write com.apple.dock show-recents -bool false

# Mute startup sound
sudo nvram StartupMute=%01

# Set main colour to graphite
defaults write -g AppleAccentColor -int -1

# Set theme to auto
defaults write -g AppleInterfaceStyleSwitchesAutomatically -bool true

# Hot Corners: Disable Screen Saver (6)
defaults write com.apple.dock wvous-tl-corner -int 6
defaults write com.apple.dock wvous-tl-modifier -int 0
defaults write com.apple.dock wvous-tr-corner -int 6
defaults write com.apple.dock wvous-tr-modifier -int 0
defaults write com.apple.dock wvous-bl-corner -int 6
defaults write com.apple.dock wvous-bl-modifier -int 0
defaults write com.apple.dock wvous-br-corner -int 6
defaults write com.apple.dock wvous-br-modifier -int 0

# Restart Dock to apply changes
killall Dock 2>/dev/null || true

# Disable globe/Fn key (emoji picker)
defaults write com.apple.HIToolbox AppleFnUsageType -int 0

# Disable click to show desktop
defaults write com.apple.WindowManager EnableStandardClickToShowDesktop -bool false

{{ if .setWallpaper }}
if [ ! -f $HOME/Pictures/wallpaper.jpeg ]; then
  wget -O $HOME/Pictures/wallpaper.jpeg https://danhughes.dev/wallpaper
fi
osascript -e 'tell application "Finder" to set desktop picture to POSIX file "'"$HOME/Pictures/wallpaper.jpeg"'"'
{{ end }}

# Show all file extensions
defaults write NSGlobalDomain AppleShowAllExtensions -bool true

# Show hidden files
defaults write com.apple.finder AppleShowAllFiles -bool true

# Finder opens to home folder
defaults write com.apple.finder NewWindowTarget -string "PfHm"
defaults write com.apple.finder NewWindowTargetPath -string "$HOME"

# Screenshots to desktop
defaults write com.apple.screencapture location "$HOME/Desktop"
defaults write com.apple.screencapture disable-shadow -bool true

# Disable auto-adjust brightness
defaults write com.apple.preference.Brightness NSAutomaticBrightnessEnabled -bool false

# Disable dim display on battery
sudo pmset -b dim 0

# Power settings: display sleep 10 min, sleep 30 min
sudo pmset -c displaysleep 10 sleep 30
sudo pmset -b displaysleep 10 sleep 30

{{ end -}}
