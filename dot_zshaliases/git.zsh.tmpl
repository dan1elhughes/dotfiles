# This alias seems to be inconsistent, so unalias it if it exists.
if which g >/dev/null 2>&1; then
	unalias g
fi

function g() {
	if [ "$#" -eq 0 ]; then
		git status --short --branch
	else
		git "$@"
	fi
}

function gcai() {
	if git diff --cached --quiet; then
		echo "gcai: no staged files to commit" >&2
		return 1
	fi

	opencode run --command commit-auto {{ .smallModelArgs }}
}
