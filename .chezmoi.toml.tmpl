{{- $persemail := promptStringOnce . "persemail" "Personal email address" "github@danhughes.dev" -}}
{{- $workemail := promptStringOnce . "workemail" "Work email address" -}}
{{- $gitsigningkey := promptStringOnce . "gitsigningkey" "1Password git signing key (leave empty to disable signing)" "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIKFfB1MJMVHebVDoYMkhA+GNmgEngOW7WvcLeSL3uhxK" -}}

{{- $brewfileChoices := list -}}
{{- range (glob (joinPath .chezmoi.sourceDir "lib/Brewfile-*")) -}}
{{-   $brewfileChoices = append $brewfileChoices (base .) -}}
{{- end -}}
{{- $brewfiles := promptMultichoiceOnce . "brewfiles" "Which Brewfiles would you like to install" $brewfileChoices $brewfileChoices -}}

{{- $resetDock := promptBoolOnce . "resetDock" "Reset dock (Unpin all, auto-hide)" true -}}
{{- $setWallpaper := promptBoolOnce . "setWallpaper" "Set wallpaper" true -}}
{{- $sudoTouchID := promptBoolOnce . "sudoTouchID" "Use TouchID for sudo" true -}}

{{- $mcpChoices := list "enode" -}}
{{- $enabledMcps := promptMultichoiceOnce . "enabledMcps" "Which MCPs would you like to enable" $mcpChoices $mcpChoices -}}

{{- $smallModelArgs := promptStringOnce . "smallModelArgs" "Small model args" "--model github-copilot/gemini-3.5-flash --variant minimal" -}}
{{- $standardModel := promptStringOnce . "standardModel" "Standard model" "openai/gpt-5.5" -}}
{{- $smartModel := promptStringOnce . "smartModel" "Smart model" "openai/gpt-5.5-pro" -}}

[data]
    persemail = {{ $persemail | quote }}
    workemail = {{ $workemail | quote }}
    gitsigningkey = {{ $gitsigningkey | quote }}
    brewfiles = {{ $brewfiles | toJson }}
    resetDock = {{ $resetDock }}
    setWallpaper = {{ $setWallpaper }}
    sudoTouchID = {{ $sudoTouchID }}
    enabledMcps = {{ $enabledMcps | toJson }}
    smallModelArgs = {{ $smallModelArgs | quote }}
    standardModel = {{ $standardModel | quote }}
    smartModel = {{ $smartModel | quote }}
[diff]
    exclude = ["externals"]
