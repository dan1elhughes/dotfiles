{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "@mohak34/opencode-notifier@latest",
  ],
  "mcp": {
    "enode": {
      "type": "remote",
      "url": "https://emcp.production.enode.com/mcp",
      "enabled": {{ has "enode" .enabledMcps }},
      "timeout": 2000
    },
    "notion": {
      "type": "remote",
      "url": "https://mcp.notion.com/mcp",
      "enabled": {{ has "notion" .enabledMcps }}
    },
    "fastmail": {
      "type": "remote",
      "url": "https://api.fastmail.com/mcp",
      "enabled": {{ has "fastmail" .enabledMcps }}
    }
  },
  "theme": "system"
}
