#!/usr/bin/env zsh

emulate -L zsh
setopt errexit nounset pipefail no_nomatch

# Shell-backed Code Swarm Review.
#
# This intentionally does not use an opencode orchestrator or opencode subagents.
# It launches each reviewer command as an ordinary background process, monitors
# those processes, writes every model's output to a temp file, then asks one
# final opencode run to synthesize/deliver from those files only.

# Default reviewer models. Edit these lists when changing the swarm.
typeset -ga DEFAULT_OPENCODE_REVIEWERS=(
	"--model openai/gpt-5.5 --variant xhigh"
	"--model github-copilot/gemini-3.1-pro-preview --variant high"
)

typeset -ga DEFAULT_CLAUDE_REVIEWERS=(
	"opus"
)

typeset SWARM_REVIEW_TEMPLATE_DIR="${SWARM_REVIEW_TEMPLATE_DIR:-${XDG_CONFIG_HOME:-$HOME/.config}/opencode/swarm-review}"

usage() {
	cat >&2 <<'EOF'
usage: swarm-review [options]

Targets:
  --worktree             review working tree/index changes from HEAD (default)
  --pr [PR]              review a PR URL/number; omit PR to use current branch PR
  --target REF           review current HEAD against merge-base with REF, or REF commit
  --base SHA --head SHA  review explicit base/head commits

Destinations:
  --local                print the final report locally (default)
  --github               post final report to the PR and print the comment link

Reviewers:
  --opencode '--model provider/model [args...]'
  --claude opus|sonnet|fable
  --no-default-reviewers

Defaults:
  configured near the top of the script in DEFAULT_OPENCODE_REVIEWERS and
  DEFAULT_CLAUDE_REVIEWERS

Environment:
  SWARM_REVIEW_FINAL_OPENCODE_ARGS   args for final synthesis opencode run
  SWARM_REVIEW_POLL_SECONDS          progress polling interval (default: 10)
  SWARM_REVIEW_TEMPLATE_DIR          prompt template directory

Examples:
  swarm-review --pr
  swarm-review --pr 123 --github
  swarm-review --target release/1.2 --local
EOF
}

log() {
	print -ru2 -- "swarm-review: $*"
}

die() {
	log "$*"
	exit 1
}

require_command() {
	command -v "$1" >/dev/null 2>&1 || die "missing required command: $1"
}

slugify() {
	local raw="$1"
	local slug
	slug="$(print -r -- "$raw" | tr '[:upper:]' '[:lower:]' | tr '/:@| ' '-----' | tr -cd '[:alnum:]._-')"
	if [[ -z "$slug" ]]; then
		slug="reviewer"
	fi
	print -r -- "$slug"
}

opencode_spec_from_args() {
	local args="$1"
	local -a words
	local i
	words=(${(z)args})
	for (( i = 1; i <= ${#words}; i++ )); do
		case "${words[$i]}" in
			--model|-m)
				if (( i < ${#words} )); then
					print -r -- "${words[$(( i + 1 ))]}"
					return 0
				fi
				;;
			--model=*)
				print -r -- "${words[$i]#--model=}"
				return 0
				;;
		esac
	done
	print -r -- "$args"
}

typeset destination="local"
typeset target_mode=""
typeset pr_ref=""
typeset target_ref=""
typeset base_override=""
typeset head_override=""
typeset use_default_reviewers="true"
typeset -a custom_opencode_reviewers custom_claude_reviewers

set_target_mode() {
	local mode="$1"
	if [[ -n "$target_mode" && "$target_mode" != "$mode" ]]; then
		die "conflicting target options: already using --$target_mode, cannot also use --$mode"
	fi
	target_mode="$mode"
}

while (( $# > 0 )); do
	case "$1" in
		-h|--help)
			usage
			exit 0
			;;
		--local)
			destination="local"
			;;
		--github)
			destination="github"
			;;
		--worktree)
			set_target_mode "worktree"
			;;
		--pr)
			set_target_mode "pr"
			if (( $# > 1 )) && [[ "$2" != --* ]]; then
				pr_ref="$2"
				shift
			fi
			;;
		--target)
			set_target_mode "target"
			(( $# > 1 )) || die "--target requires a value"
			target_ref="$2"
			shift
			;;
		--base)
			(( $# > 1 )) || die "--base requires a value"
			set_target_mode "explicit"
			base_override="$2"
			shift
			;;
		--head)
			(( $# > 1 )) || die "--head requires a value"
			set_target_mode "explicit"
			head_override="$2"
			shift
			;;
		--opencode)
			(( $# > 1 )) || die "--opencode requires 'Label|args'"
			custom_opencode_reviewers+=("$2")
			shift
			;;
		--claude)
			(( $# > 1 )) || die "--claude requires 'Label|alias'"
			custom_claude_reviewers+=("$2")
			shift
			;;
		--no-default-reviewers)
			use_default_reviewers="false"
			;;
		*)
			die "unknown argument: $1"
			;;
	esac
	shift
done

require_command git
require_command jq
require_command opencode

repo_root="$(git rev-parse --show-toplevel 2>/dev/null)" || die "not inside a git repository"
cd "$repo_root"

if [[ -z "$target_mode" ]]; then
	target_mode="worktree"
fi

if [[ "$destination" == "github" && "$target_mode" != "pr" ]]; then
	die "--github requires a PR target; add --pr [PR]"
fi

typeset tmpdir
tmpdir="$(mktemp -d "${TMPDIR:-/tmp}/swarm-review.XXXXXX")" || die "failed to create temp directory"
log "workspace: $tmpdir"

typeset readonly_opencode_config_file="$tmpdir/opencode-reviewer-readonly.json"
cat > "$readonly_opencode_config_file" <<'EOF'
{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "edit": "deny",
    "bash": "deny"
  }
}
EOF

typeset target_metadata_file="$tmpdir/target.md"
typeset failures_file="$tmpdir/reviewer-failures.md"
: > "$failures_file"

typeset TARGET_KIND=""
typeset TARGET_SUMMARY=""
typeset BASE_COMMIT=""
typeset HEAD_COMMIT=""
typeset PR_NUMBER=""
typeset PR_URL=""
typeset PR_BASE_REF=""
typeset PR_HEAD_REF=""
typeset PR_HEAD_OID=""

resolve_worktree_target() {
	local git_status
	git_status="$(git status --short)"
	[[ -n "$git_status" ]] || die "working tree is clean; nothing to review"

	TARGET_KIND="working-tree"
	BASE_COMMIT="$(git rev-parse HEAD)"
	HEAD_COMMIT="WORKTREE"
	TARGET_SUMMARY="working tree and index changes from HEAD (${BASE_COMMIT})"

	{
		print -r -- "# Review target"
		print -r -- ""
		print -r -- "Target kind: working tree"
		print -r -- "Repository: $repo_root"
		print -r -- "Base commit: $BASE_COMMIT"
		print -r -- "Head: working tree/index (not a commit)"
		print -r -- "Base branch: not applicable"
		print -r -- "Suggested diff commands:"
		print -r -- "- git diff HEAD"
		print -r -- "- git diff --cached HEAD"
		print -r -- ""
		print -r -- "Git status:"
		print -r -- '```'
		print -r -- "$git_status"
		print -r -- '```'
	} > "$target_metadata_file"
}

resolve_explicit_commits_target() {
	[[ -n "$base_override" && -n "$head_override" ]] || die "--base and --head must be provided together"
	BASE_COMMIT="$(git rev-parse "${base_override}^{commit}")" || die "invalid base commit: $base_override"
	HEAD_COMMIT="$(git rev-parse "${head_override}^{commit}")" || die "invalid head commit: $head_override"
	TARGET_KIND="explicit-commits"
	TARGET_SUMMARY="explicit commit range ${BASE_COMMIT}..${HEAD_COMMIT}"

	{
		print -r -- "# Review target"
		print -r -- ""
		print -r -- "Target kind: explicit commits"
		print -r -- "Repository: $repo_root"
		print -r -- "Base commit: $BASE_COMMIT"
		print -r -- "Head commit: $HEAD_COMMIT"
		print -r -- "Base branch: explicitly provided; not assumed to be main"
		print -r -- "Suggested diff command: git diff $BASE_COMMIT $HEAD_COMMIT"
	} > "$target_metadata_file"
}

resolve_ref_target() {
	local ref="$1"
	local head
	head="$(git rev-parse HEAD)"

	if git show-ref --verify --quiet "refs/heads/$ref" || git show-ref --verify --quiet "refs/remotes/$ref" || git show-ref --verify --quiet "refs/remotes/origin/$ref"; then
		local base
		base="$(git merge-base "$ref" HEAD 2>/dev/null || git merge-base "origin/$ref" HEAD 2>/dev/null)" || die "could not find merge-base for $ref and HEAD"
		TARGET_KIND="branch-range"
		BASE_COMMIT="$base"
		HEAD_COMMIT="$head"
		TARGET_SUMMARY="HEAD compared with merge-base against $ref (${BASE_COMMIT}..${HEAD_COMMIT}); base is not assumed to be main"
		{
			print -r -- "# Review target"
			print -r -- ""
			print -r -- "Target kind: branch range"
			print -r -- "Repository: $repo_root"
			print -r -- "Base ref: $ref (not assumed to be main)"
			print -r -- "Base commit: $BASE_COMMIT"
			print -r -- "Head commit: $HEAD_COMMIT"
			print -r -- "Suggested diff command: git diff $BASE_COMMIT $HEAD_COMMIT"
		} > "$target_metadata_file"
		return 0
	fi

	local commit
	commit="$(git rev-parse "${ref}^{commit}")" || die "invalid target ref: $ref"
	BASE_COMMIT="$(git rev-parse "${commit}^" 2>/dev/null)" || die "target commit has no parent: $ref"
	HEAD_COMMIT="$commit"
	TARGET_KIND="single-commit"
	TARGET_SUMMARY="single commit ${BASE_COMMIT}..${HEAD_COMMIT}"
	{
		print -r -- "# Review target"
		print -r -- ""
		print -r -- "Target kind: single commit"
		print -r -- "Repository: $repo_root"
		print -r -- "Base commit: $BASE_COMMIT"
		print -r -- "Head commit: $HEAD_COMMIT"
		print -r -- "Base branch: commit parent; not assumed to be main"
		print -r -- "Suggested diff command: git diff $BASE_COMMIT $HEAD_COMMIT"
		print -r -- ""
		git show --no-patch --format=fuller "$HEAD_COMMIT"
	} > "$target_metadata_file"
}

resolve_pr_target() {
	require_command gh

	local -a view_cmd
	if [[ -n "$pr_ref" ]]; then
		view_cmd=(gh pr view "$pr_ref" --json number,url,title,headRefName,headRefOid,baseRefName,baseRefOid)
	else
		view_cmd=(gh pr view --json number,url,title,headRefName,headRefOid,baseRefName,baseRefOid)
	fi

	local pr_json
	pr_json="$(${view_cmd[@]})" || die "could not resolve PR; pass --pr <number-or-url> or run from a branch with an associated PR"

	PR_NUMBER="$(jq -r '.number' <<< "$pr_json")"
	PR_URL="$(jq -r '.url' <<< "$pr_json")"
	PR_BASE_REF="$(jq -r '.baseRefName' <<< "$pr_json")"
	PR_HEAD_REF="$(jq -r '.headRefName' <<< "$pr_json")"
	PR_HEAD_OID="$(jq -r '.headRefOid' <<< "$pr_json")"
	local base_ref_oid
	base_ref_oid="$(jq -r '.baseRefOid' <<< "$pr_json")"

	git fetch --quiet origin "$PR_BASE_REF" >/dev/null 2>&1 || true
	git fetch --quiet origin "pull/${PR_NUMBER}/head:refs/remotes/origin/pull/${PR_NUMBER}/head" >/dev/null 2>&1 || true

	if git rev-parse --verify -q "refs/remotes/origin/pull/${PR_NUMBER}/head^{commit}" >/dev/null 2>&1; then
		HEAD_COMMIT="$(git rev-parse "refs/remotes/origin/pull/${PR_NUMBER}/head^{commit}")"
	else
		HEAD_COMMIT="$PR_HEAD_OID"
	fi

	BASE_COMMIT=""
	if git rev-parse --verify -q "origin/${PR_BASE_REF}^{commit}" >/dev/null 2>&1 && git rev-parse --verify -q "${HEAD_COMMIT}^{commit}" >/dev/null 2>&1; then
		BASE_COMMIT="$(git merge-base "origin/${PR_BASE_REF}" "$HEAD_COMMIT" 2>/dev/null || true)"
	fi
	if [[ -z "$BASE_COMMIT" || "$BASE_COMMIT" == "null" ]]; then
		BASE_COMMIT="$base_ref_oid"
	fi

	TARGET_KIND="pull-request"
	TARGET_SUMMARY="PR #${PR_NUMBER} ${BASE_COMMIT}..${HEAD_COMMIT} (base branch ${PR_BASE_REF}, not assumed to be main)"

	{
		print -r -- "# Review target"
		print -r -- ""
		print -r -- "Target kind: pull request"
		print -r -- "Repository: $repo_root"
		print -r -- "PR: #$PR_NUMBER"
		print -r -- "PR URL: $PR_URL"
		print -r -- "Base ref: $PR_BASE_REF (not assumed to be main)"
		print -r -- "Base commit: $BASE_COMMIT"
		print -r -- "Head ref: $PR_HEAD_REF"
		print -r -- "Head commit: $HEAD_COMMIT"
		print -r -- "Suggested diff commands:"
		print -r -- "- git diff $BASE_COMMIT $HEAD_COMMIT"
		print -r -- "- gh pr diff $PR_NUMBER"
	} > "$target_metadata_file"
}

case "$target_mode" in
	explicit)
		resolve_explicit_commits_target
		;;
	pr)
		resolve_pr_target
		;;
	target)
		resolve_ref_target "$target_ref"
		;;
	worktree)
		resolve_worktree_target
		;;
	*)
		die "unsupported target mode: $target_mode"
		;;
esac

if [[ "$HEAD_COMMIT" != "WORKTREE" ]] && git rev-parse --verify -q "${BASE_COMMIT}^{commit}" >/dev/null 2>&1 && git rev-parse --verify -q "${HEAD_COMMIT}^{commit}" >/dev/null 2>&1; then
	if git diff --quiet "$BASE_COMMIT" "$HEAD_COMMIT"; then
		die "resolved target diff is empty: $TARGET_SUMMARY"
	fi
fi

log "target: $TARGET_SUMMARY"
log "destination: $destination"

typeset -a REVIEW_LABELS REVIEW_KIND REVIEW_SPEC REVIEW_ARGS REVIEW_SLUG REVIEW_FILE AGREEMENT_FILE

add_opencode_reviewer() {
	local args="$1"
	local spec
	# Backward-compatible: accept and ignore a legacy Label|args prefix.
	if [[ "$args" == *"|"* ]]; then
		args="${args#*|}"
	fi
	spec="$(opencode_spec_from_args "$args")"
	REVIEW_LABELS+=("$spec")
	REVIEW_KIND+=("opencode")
	REVIEW_SPEC+=("$spec")
	REVIEW_ARGS+=("$args")
	REVIEW_SLUG+=("$(slugify "$spec")")
}

add_claude_reviewer() {
	local model="$1"
	local spec
	# Backward-compatible: accept and ignore a legacy Label|model prefix.
	if [[ "$model" == *"|"* ]]; then
		model="${model#*|}"
	fi
	case "$model" in
		opus|sonnet|fable) ;;
		*) die "unsupported Claude model '$model'; use opus, sonnet, or fable" ;;
	esac
	spec="claude/$model"
	REVIEW_LABELS+=("$spec")
	REVIEW_KIND+=("claude")
	REVIEW_SPEC+=("$spec")
	REVIEW_ARGS+=("$model")
	REVIEW_SLUG+=("$(slugify "$spec")")
}

if [[ "$use_default_reviewers" == "true" ]]; then
	for reviewer in "${DEFAULT_OPENCODE_REVIEWERS[@]}"; do
		add_opencode_reviewer "$reviewer"
	done
	for reviewer in "${DEFAULT_CLAUDE_REVIEWERS[@]}"; do
		add_claude_reviewer "$reviewer"
	done
fi

for reviewer in "${custom_opencode_reviewers[@]}"; do
	add_opencode_reviewer "$reviewer"
done

for reviewer in "${custom_claude_reviewers[@]}"; do
	add_claude_reviewer "$reviewer"
done

(( ${#REVIEW_LABELS} > 0 )) || die "no reviewers configured"

if (( ${REVIEW_KIND[(I)claude]} > 0 )); then
	require_command claude
fi

typeset -a JOB_LABELS JOB_PIDS JOB_OUTPUTS JOB_LOGS JOB_STATUS

reset_jobs() {
	JOB_LABELS=()
	JOB_PIDS=()
	JOB_OUTPUTS=()
	JOB_LOGS=()
	JOB_STATUS=()
}

start_job() {
	local label="$1"
	local output="$2"
	local log_file="$3"
	local status_file="$4"
	local stdin_file="$5"
	shift 5

	: > "$output"
	: > "$log_file"
	: > "$status_file.pending"
	rm -f "$status_file"

	(
		set +e
		if [[ -n "$stdin_file" ]]; then
			"$@" < "$stdin_file" > "$output" 2> "$log_file"
		else
			"$@" > "$output" 2> "$log_file"
		fi
		local code=$?
		print -r -- "$code" > "$status_file"
		rm -f "$status_file.pending"
		exit 0
	) &

	local pid=$!
	JOB_LABELS+=("$label")
	JOB_PIDS+=("$pid")
	JOB_OUTPUTS+=("$output")
	JOB_LOGS+=("$log_file")
	JOB_STATUS+=("$status_file")
	log "started $label (pid $pid)"
}

file_bytes() {
	local file="$1"
	if [[ -f "$file" ]]; then
		wc -c < "$file" | tr -d '[:space:]'
	else
		print -r -- "0"
	fi
}

monitor_jobs() {
	local phase="$1"
	local poll_seconds="${SWARM_REVIEW_POLL_SECONDS:-10}"
	local total=${#JOB_PIDS}
	local done_count state code out_bytes log_bytes running_count previous_lines
	previous_lines=0

	while true; do
		done_count=0
		running_count=0

		if [[ -t 2 && "$previous_lines" -gt 0 ]]; then
			print -nru2 -- $'\033['"$previous_lines"$'A'
			print -nru2 -- $'\033[J'
		fi

		print -ru2 -- "swarm-review: $phase progress"
		for (( i = 1; i <= total; i++ )); do
			if [[ -f "${JOB_STATUS[$i]}" ]]; then
				code="$(< "${JOB_STATUS[$i]}")"
				if [[ "$code" == "0" ]]; then
					state="done"
				else
					state="failed($code)"
				fi
				done_count=$(( done_count + 1 ))
			elif kill -0 "${JOB_PIDS[$i]}" 2>/dev/null; then
				state="running"
				running_count=$(( running_count + 1 ))
			else
				state="finishing"
			fi

			out_bytes="$(file_bytes "${JOB_OUTPUTS[$i]}")"
			log_bytes="$(file_bytes "${JOB_LOGS[$i]}")"
			print -ru2 -- "  - ${JOB_LABELS[$i]}: $state, output=${out_bytes}B, log=${log_bytes}B"
		done
		previous_lines=$(( total + 1 ))

		if (( done_count == total )); then
			break
		fi

		sleep "$poll_seconds"
	done

	for pid in "${JOB_PIDS[@]}"; do
		wait "$pid" 2>/dev/null || true
	done
}

record_failure() {
	local label="$1"
	local phase="$2"
	local status_file="$3"
	local log_file="$4"
	local output_file="$5"
	local code="missing-status"
	if [[ -f "$status_file" ]]; then
		code="$(< "$status_file")"
	fi
	{
		print -r -- "- $label failed during $phase (exit: $code)."
		if [[ -s "$log_file" ]]; then
			print -r -- "  - Log tail:"
			print -r -- '```'
			tail -n 40 "$log_file"
			print -r -- '```'
		fi
	} >> "$failures_file"
}

typeset -A TEMPLATE_VARS

template_path() {
	local name="$1"
	local path="$SWARM_REVIEW_TEMPLATE_DIR/$name"
	[[ -r "$path" ]] || die "missing prompt template: $path"
	print -r -- "$path"
}

render_template_to_file() {
	local template="$1"
	local output="$2"
	local content key marker
	content="$(< "$template")"
	for key in "${(k)TEMPLATE_VARS[@]}"; do
		marker="{{${key}}}"
		content="${content//$marker/${TEMPLATE_VARS[$key]}}"
	done
	print -r -- "$content" > "$output"
}

other_initial_reviews_block() {
	local idx="$1"
	local emitted="false"
	for (( j = 1; j <= ${#REVIEW_LABELS}; j++ )); do
		if (( j == idx )) || [[ ! -s "${REVIEW_FILE[$j]}" ]]; then
			continue
		fi
		emitted="true"
		print -r -- "### ${REVIEW_LABELS[$j]} (${REVIEW_SPEC[$j]})"
		print -r -- '```markdown'
		cat "${REVIEW_FILE[$j]}"
		print -r -- '```'
		print -r -- ""
	done
	if [[ "$emitted" != "true" ]]; then
		print -r -- "No other successful initial reviews."
	fi
}

reviewers_block() {
	for (( i = 1; i <= ${#REVIEW_LABELS}; i++ )); do
		if [[ -s "${REVIEW_FILE[$i]}" ]]; then
			print -r -- "- ${REVIEW_LABELS[$i]} - ${REVIEW_SPEC[$i]}"
		fi
	done
}

reviewer_failures_block() {
	if [[ -s "$failures_file" ]]; then
		print -r -- "## Reviewer failures to include"
		print -r -- ""
		cat "$failures_file"
	fi
}

initial_reviews_block() {
	for (( i = 1; i <= ${#REVIEW_LABELS}; i++ )); do
		if [[ ! -s "${REVIEW_FILE[$i]}" ]]; then
			continue
		fi
		print -r -- "### ${REVIEW_LABELS[$i]} (${REVIEW_SPEC[$i]})"
		print -r -- '```markdown'
		cat "${REVIEW_FILE[$i]}"
		print -r -- '```'
		print -r -- ""
	done
}

agreement_passes_block() {
	for (( i = 1; i <= ${#REVIEW_LABELS}; i++ )); do
		if [[ ! -s "${AGREEMENT_FILE[$i]}" ]]; then
			continue
		fi
		print -r -- "### ${REVIEW_LABELS[$i]} (${REVIEW_SPEC[$i]})"
		print -r -- '```markdown'
		cat "${AGREEMENT_FILE[$i]}"
		print -r -- '```'
		print -r -- ""
	done
}

pr_delivery_metadata_block() {
	if [[ "$destination" == "github" ]]; then
		print -r -- "## PR metadata"
		print -r -- ""
		print -r -- "PR number: ${PR_NUMBER:-unresolved}"
		print -r -- "PR URL: ${PR_URL:-unresolved}"
		print -r -- "PR head commit: ${PR_HEAD_OID:-$HEAD_COMMIT}"
		print -r -- "Base ref: ${PR_BASE_REF:-unknown}"
		print -r -- ""
		print -r -- "Resolve repo with: gh repo view --json nameWithOwner -q .nameWithOwner"
		print -r -- "Resolve PR with: gh pr view ${PR_NUMBER:-} --json number,headRefOid,baseRefName"
	fi
}

write_initial_prompt() {
	local label="$1"
	local spec="$2"
	local output_file="$3"
	local prompt_file="$4"

	TEMPLATE_VARS=()
	TEMPLATE_VARS[LABEL]="$label"
	TEMPLATE_VARS[SPEC]="$spec"
	TEMPLATE_VARS[TARGET_METADATA]="$(< "$target_metadata_file")"
	render_template_to_file "$(template_path initial-review.md)" "$prompt_file"
}

write_agreement_prompt() {
	local idx="$1"
	local prompt_file="$2"
	local label="${REVIEW_LABELS[$idx]}"
	local spec="${REVIEW_SPEC[$idx]}"
	local output_file="${AGREEMENT_FILE[$idx]}"

	TEMPLATE_VARS=()
	TEMPLATE_VARS[LABEL]="$label"
	TEMPLATE_VARS[SPEC]="$spec"
	TEMPLATE_VARS[TARGET_METADATA]="$(< "$target_metadata_file")"
	TEMPLATE_VARS[OWN_INITIAL_REVIEW]="$(< "${REVIEW_FILE[$idx]}")"
	TEMPLATE_VARS[OTHER_INITIAL_REVIEWS]="$(other_initial_reviews_block "$idx")"
	render_template_to_file "$(template_path agreement.md)" "$prompt_file"
}

write_final_prompt() {
	local prompt_file="$1"
	local final_report="$2"

	TEMPLATE_VARS=()
	TEMPLATE_VARS[TARGET_METADATA]="$(< "$target_metadata_file")"
	TEMPLATE_VARS[REVIEWERS_BLOCK]="$(reviewers_block)"
	TEMPLATE_VARS[REVIEWER_FAILURES_BLOCK]="$(reviewer_failures_block)"
	TEMPLATE_VARS[INITIAL_REVIEWS_BLOCK]="$(initial_reviews_block)"
	TEMPLATE_VARS[AGREEMENT_PASSES_BLOCK]="$(agreement_passes_block)"
	TEMPLATE_VARS[PR_DELIVERY_METADATA_BLOCK]="$(pr_delivery_metadata_block)"
	render_template_to_file "$(template_path final-synthesis.md)" "$prompt_file"
}

post_github_report() {
	local report_file="$1"
	local request_file="$2"
	local repo comment_url

	repo="$(gh repo view --json nameWithOwner -q .nameWithOwner)" || die "could not resolve GitHub repository"
	jq -n --rawfile body "$report_file" '{body: $body}' > "$request_file"
	comment_url="$(gh api "repos/${repo}/issues/${PR_NUMBER}/comments" --method POST --input "$request_file" --jq .html_url)" || die "failed to post final report to GitHub"
	[[ -n "$comment_url" && "$comment_url" != "null" ]] || die "GitHub did not return a comment URL"

	print -r -- "$comment_url"
}

reset_jobs

for (( i = 1; i <= ${#REVIEW_LABELS}; i++ )); do
	slug="${REVIEW_SLUG[$i]}"
	review_file="$tmpdir/${slug}-review.md"
	prompt_file="$tmpdir/${slug}-initial-prompt.md"
	log_file="$tmpdir/${slug}-review.log"
	status_file="$tmpdir/${slug}-review.status"
	REVIEW_FILE[$i]="$review_file"
	AGREEMENT_FILE[$i]="$tmpdir/${slug}-agreement.md"

	write_initial_prompt "${REVIEW_LABELS[$i]}" "${REVIEW_SPEC[$i]}" "$review_file" "$prompt_file"

	case "${REVIEW_KIND[$i]}" in
		opencode)
			args=(${(z)REVIEW_ARGS[$i]})
			start_job "${REVIEW_LABELS[$i]} initial" "$review_file" "$log_file" "$status_file" "" \
				env OPENCODE_CONFIG="$readonly_opencode_config_file" opencode run "${args[@]}" \
				"Follow the attached Code Swarm Review initial prompt exactly. Return only the requested markdown." \
				--file "$prompt_file"
			;;
		claude)
			start_job "${REVIEW_LABELS[$i]} initial" "$review_file" "$log_file" "$status_file" "$prompt_file" \
				claude --model "${REVIEW_ARGS[$i]}" -p
			;;
	esac
done

monitor_jobs "initial review"

typeset -a successful_indices
successful_indices=()
for (( i = 1; i <= ${#REVIEW_LABELS}; i++ )); do
	status_file="$tmpdir/${REVIEW_SLUG[$i]}-review.status"
	log_file="$tmpdir/${REVIEW_SLUG[$i]}-review.log"
	if [[ -f "$status_file" && "$(< "$status_file")" == "0" && -s "${REVIEW_FILE[$i]}" ]]; then
		successful_indices+=("$i")
	else
		record_failure "${REVIEW_LABELS[$i]}" "initial review" "$status_file" "$log_file" "${REVIEW_FILE[$i]}"
	fi
done

(( ${#successful_indices} > 0 )) || die "all initial reviewers failed; see $failures_file"

reset_jobs

for idx in "${successful_indices[@]}"; do
	slug="${REVIEW_SLUG[$idx]}"
	prompt_file="$tmpdir/${slug}-agreement-prompt.md"
	agreement_file="${AGREEMENT_FILE[$idx]}"
	log_file="$tmpdir/${slug}-agreement.log"
	status_file="$tmpdir/${slug}-agreement.status"

	write_agreement_prompt "$idx" "$prompt_file"

	case "${REVIEW_KIND[$idx]}" in
		opencode)
			args=(${(z)REVIEW_ARGS[$idx]})
			start_job "${REVIEW_LABELS[$idx]} agreement" "$agreement_file" "$log_file" "$status_file" "" \
				env OPENCODE_CONFIG="$readonly_opencode_config_file" opencode run "${args[@]}" \
				"Follow the attached Code Swarm Review agreement prompt exactly. Return only the requested markdown." \
				--file "$prompt_file"
			;;
		claude)
			start_job "${REVIEW_LABELS[$idx]} agreement" "$agreement_file" "$log_file" "$status_file" "$prompt_file" \
				claude --model "${REVIEW_ARGS[$idx]}" -p
			;;
	esac
done

monitor_jobs "agreement"

for idx in "${successful_indices[@]}"; do
	status_file="$tmpdir/${REVIEW_SLUG[$idx]}-agreement.status"
	log_file="$tmpdir/${REVIEW_SLUG[$idx]}-agreement.log"
	if [[ ! -f "$status_file" || "$(< "$status_file")" != "0" || ! -s "${AGREEMENT_FILE[$idx]}" ]]; then
		record_failure "${REVIEW_LABELS[$idx]}" "agreement" "$status_file" "$log_file" "${AGREEMENT_FILE[$idx]}"
	fi
done

final_prompt="$tmpdir/final-prompt.md"
final_report="$tmpdir/final-report.md"
github_comment_request="$tmpdir/github-comment-request.json"
final_log="$tmpdir/final.log"
final_status="$tmpdir/final.status"
final_args_string="${SWARM_REVIEW_FINAL_OPENCODE_ARGS:-}"
write_final_prompt "$final_prompt" "$final_report"

final_args=()
if [[ -n "$final_args_string" ]]; then
	final_args=(${(z)final_args_string})
fi

reset_jobs
start_job "final synthesis" "$final_report" "$final_log" "$final_status" "" \
	opencode run "${final_args[@]}" \
	"Follow the attached Code Swarm Review final synthesis prompt exactly." \
	--file "$final_prompt"
monitor_jobs "final synthesis"

if [[ ! -f "$final_status" || "$(< "$final_status")" != "0" || ! -s "$final_report" ]]; then
	record_failure "Final synthesis" "final synthesis" "$final_status" "$final_log" "$final_report"
	die "final synthesis failed; see $final_log and $failures_file"
fi

log "final report: $final_report"
log "scratch files kept in: $tmpdir"

if [[ "$destination" == "github" ]]; then
	post_github_report "$final_report" "$github_comment_request"
else
	cat "$final_report"
fi
