font-size = 18
font-family = Twilio Sans Mono
theme = dark:Ayu Mirage,light:Ayu Light
quit-after-last-window-closed = true

# Cmd+O opens a new tab, then types and runs opencode in it.
keybind = cmd+o=text:osascript -e 'tell application "Ghostty"' -e 'set cfg to new surface configuration' -e 'set initial input of cfg to "opencode" & return' -e 'set t to new tab in front window with configuration cfg' -e 'select tab t' -e 'end tell'\r
